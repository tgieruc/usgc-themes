{
  "$schema": "vscode://schemas/color-theme",
  "name": "USGC POLYIMIDE",
  "type": "dark",
  "semanticHighlighting": true,
  "_comment": "Optimized for Monaspace font family - see recommended-settings.json",
  "colors": {
    "focusBorder": "#FFBF00AA",
    "foreground": "#E9CC7A",

    "editor.background": "#000000",
    "editor.foreground": "#E9CC7A",
    "editor.lineHighlightBackground": "#FFBF001A",
    "editor.selectionBackground": "#003366AA",
    "editor.inactiveSelectionBackground": "#00224466",
    "editor.selectionForeground": "#E9F7FF",
    "editor.wordHighlightBackground": "#00336655",
    "editor.wordHighlightStrongBackground": "#00448866",
    "editor.findMatchBackground": "#FFBF0033",
    "editor.findMatchHighlightBackground": "#FFBF001F",
    "editor.findRangeHighlightBackground": "#00448833",
    "editorBracketMatch.background": "#00448866",
    "editorBracketMatch.border": "#00FFFF66",
    "editorGutter.addedBackground": "#00A645CC",
    "editorGutter.modifiedBackground": "#00FFFFCC",
    "editorGutter.deletedBackground": "#FF4D4DCC",
    "editorIndentGuide.background1": "#3A3A3A",
    "editorIndentGuide.activeBackground1": "#5A5A5A",
    "editorLineNumber.foreground": "#FF6600",
    "editorLineNumber.activeForeground": "#FFFFFF",
    "editorRuler.foreground": "#333333",
    "editorWhitespace.foreground": "#2A2A2A",
    "editorCursor.foreground": "#00A645",

    "editorHoverWidget.background": "#0A0A0A",
    "editorHoverWidget.border": "#444444",
    "editorSuggestWidget.background": "#0A0A0A",
    "editorSuggestWidget.border": "#444444",
    "editorSuggestWidget.foreground": "#E9CC7A",
    "editorSuggestWidget.selectedBackground": "#003366",
    "editorWidget.background": "#0A0A0A",

    "activityBar.background": "#000000",
    "activityBar.foreground": "#FFBF00",
    "activityBar.activeBorder": "#FFBF00",
    "activityBarBadge.background": "#FF6600",
    "activityBarBadge.foreground": "#000000",

    "badge.background": "#FF6600",
    "badge.foreground": "#000000",

    "button.background": "#FF6600",
    "button.foreground": "#000000",
    "button.hoverBackground": "#CC4400",

    "contrastActiveBorder": "#FFBF0044",
    "contrastBorder": "#121212",

    "list.activeSelectionBackground": "#003366",
    "list.activeSelectionForeground": "#E6FEFF",
    "list.inactiveSelectionBackground": "#1A1A1A",
    "list.hoverBackground": "#121212",
    "list.highlightForeground": "#00FFFF",

    "panel.background": "#000000",
    "panel.border": "#333333",
    "panelTitle.activeBorder": "#FFBF00",
    "panelTitle.activeForeground": "#FFBF00",
    "panelTitle.inactiveForeground": "#888888",

    "peekView.border": "#FFBF00",
    "peekViewEditor.background": "#000000",
    "peekViewResult.background": "#000000",
    "peekViewTitle.background": "#000000",
    "peekViewEditor.matchHighlightBackground": "#FFBF0026",
    "peekViewResult.matchHighlightBackground": "#FFBF0026",

    "scrollbar.shadow": "#000000",
    "scrollbarSlider.background": "#55555599",
    "scrollbarSlider.hoverBackground": "#777777AA",
    "scrollbarSlider.activeBackground": "#999999AA",

    "sideBar.background": "#000000",
    "sideBar.foreground": "#FFBF00",
    "sideBarSectionHeader.background": "#000000",
    "sideBarSectionHeader.foreground": "#FFBF00",
    "sideBarTitle.foreground": "#FFBF00",

    "statusBar.background": "#000000",
    "statusBar.foreground": "#FFBF00",
    "statusBar.debuggingBackground": "#B00020",
    "statusBar.debuggingForeground": "#FFFFFF",
    "statusBar.noFolderBackground": "#000000",
    "statusBar.noFolderForeground": "#FFBF00",
    "statusBarItem.hoverBackground": "#1A1A1A",

    "tab.activeBackground": "#081A33",
    "tab.activeForeground": "#E6FEFF",
    "tab.activeBorderTop": "#00FFFF",
    "tab.border": "#222222",
    "tab.inactiveBackground": "#000000",
    "tab.inactiveForeground": "#888888",

    "terminal.background": "#000000",
    "terminal.foreground": "#E9CC7A",
    "terminalCursor.foreground": "#00A645",

    "titleBar.activeBackground": "#000000",
    "titleBar.activeForeground": "#FFBF00",
    "titleBar.inactiveBackground": "#000000",
    "titleBar.inactiveForeground": "#888888",

    "sash.hoverBorder": "#00FFFF",

    "errorForeground": "#FF4D4D",
    "editorError.foreground": "#FF4D4D",
    "editorWarning.foreground": "#FFC107",
    "editorInfo.foreground": "#00FFFF",
    "editorHint.foreground": "#00A645",

    "diffEditor.insertedTextBackground": "#00A64522",
    "diffEditor.removedTextBackground": "#FF4D4D22",

    "gitDecoration.addedResourceForeground": "#00A645",
    "gitDecoration.modifiedResourceForeground": "#00FFFF",
    "gitDecoration.deletedResourceForeground": "#FF4D4D",
    "gitDecoration.untrackedResourceForeground": "#00A645",
    "gitDecoration.ignoredResourceForeground": "#666666",

    "dropdown.background": "#0A0A0A",
    "input.background": "#0A0A0A",
    "input.border": "#333333",
    "inputOption.activeBorder": "#FFBF00",

    "editorBracketHighlight.foreground1": "#FFBF00",
    "editorBracketHighlight.foreground2": "#00FFFF",
    "editorBracketHighlight.foreground3": "#00A645",
    "editorBracketHighlight.foreground4": "#FF6600",
    "editorBracketHighlight.foreground5": "#FF00FF",
    "editorBracketHighlight.foreground6": "#66CCFF",
    "editorBracketPairGuide.activeBackground1": "#FFBF0044",
    "editorBracketPairGuide.activeBackground2": "#00FFFF44",
    "editorBracketPairGuide.activeBackground3": "#00A64544",
    "editorBracketPairGuide.activeBackground4": "#FF660044",
    "editorBracketPairGuide.activeBackground5": "#FF00FF44",
    "editorBracketPairGuide.activeBackground6": "#66CCFF44",

    "terminal.ansiBlack": "#000000",
    "terminal.ansiRed": "#FF4D4D",
    "terminal.ansiGreen": "#00A645",
    "terminal.ansiYellow": "#FFBF00",
    "terminal.ansiBlue": "#66B2FF",
    "terminal.ansiMagenta": "#FF00FF",
    "terminal.ansiCyan": "#00FFFF",
    "terminal.ansiWhite": "#E9CC7A",
    "terminal.ansiBrightBlack": "#555555",
    "terminal.ansiBrightRed": "#FF6666",
    "terminal.ansiBrightGreen": "#00C25A",
    "terminal.ansiBrightYellow": "#FFD166",
    "terminal.ansiBrightBlue": "#99CCFF",
    "terminal.ansiBrightMagenta": "#FF66FF",
    "terminal.ansiBrightCyan": "#66FFFF",
    "terminal.ansiBrightWhite": "#FFF2C2"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": { "fontStyle": "italic", "foreground": "#8A8A8A" }
    },
    {
      "name": "Variables",
      "scope": ["variable", "meta.definition.variable"],
      "settings": { "foreground": "#FFBF00" }
    },
    {
      "name": "Properties",
      "scope": ["variable.other.property", "meta.object-literal.key"],
      "settings": { "foreground": "#FFD166" }
    },
    {
      "name": "Parameters",
      "scope": ["variable.parameter"],
      "settings": { "foreground": "#E6E6E6" }
    },
    {
      "name": "Constants & Escapes",
      "scope": [
        "constant",
        "entity.name.constant",
        "constant.character",
        "constant.escape"
      ],
      "settings": { "foreground": "#FFFF66" }
    },
    {
      "name": "Keywords & Storage",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": { "foreground": "#66CCFF" }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": { "foreground": "#FF5555" }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.template"],
      "settings": { "foreground": "#00C25A" }
    },
    {
      "name": "String Interpolation / Template Punctuation",
      "scope": [
        "punctuation.definition.template-expression",
        "meta.template.expression"
      ],
      "settings": { "foreground": "#00FFFF" }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "meta.require",
        "support.function.any-method",
        "variable.function"
      ],
      "settings": { "foreground": "#00FFFF" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": { "foreground": "#FF6600" }
    },
    {
      "name": "Built-in constants",
      "scope": ["constant.language", "support.constant"],
      "settings": { "foreground": "#FF66FF" }
    },
    {
      "name": "Classes & Types",
      "scope": ["entity.name.class", "entity.name.type.class", "support.type"],
      "settings": { "foreground": "#00A645" }
    },
    {
      "name": "Annotations / Decorators",
      "scope": ["storage.type.annotation", "meta.decorator"],
      "settings": { "foreground": "#FF66FF" }
    },
    {
      "name": "Imports & Modules",
      "scope": ["keyword.control.import", "entity.name.module"],
      "settings": { "foreground": "#66CCFF" }
    },
    {
      "name": "JSON Keys",
      "scope": ["support.type.property-name.json"],
      "settings": { "foreground": "#FFD166" }
    },
    {
      "name": "CSS/LESS/SASS Properties",
      "scope": ["support.type.property-name.css", "meta.property-name"],
      "settings": { "foreground": "#FFD166" }
    },
    {
      "name": "Tags",
      "scope": ["entity.name.tag", "meta.tag.sgml"],
      "settings": { "foreground": "#00FFFF" }
    },
    {
      "name": "Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": { "foreground": "#FFBF00" }
    }
  ]
}
